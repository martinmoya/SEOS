# Default LLM Provider (lmstudio, ollama, openai, claude, gemini)
LLM_PROVIDER=lmstudio

# Local Settings (LM Studio / Ollama)
LMSTUDIO_URL=http://127.0.0.1:1234/v1
OLLAMA_URL=http://127.0.0.1:11434

# Default Model & Generation Settings
MODEL=meta-llama-3-8b-instruct
TEMPERATURE=0.7
MAX_TOKENS=4096

# Cloud AI Keys (Only required if LLM_PROVIDER is set to cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20240620

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Optional: GitHub Integration
GITHUB_TOKEN=ghp_your_token_here