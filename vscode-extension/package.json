{
  "name": "seos-vscode",
  "displayName": "SEOS",
  "description": "SEOS integration for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seos.explainCode",
        "title": "SEOS: Explain Code"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "seos.explainCode",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.5"
  }
}